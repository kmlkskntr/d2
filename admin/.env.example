# Admin panel ortam değişkenleri (opsiyonel).

# Backend API adresi. Boşsa dev'de Vite proxy /api'yi http://localhost:4000'e yönlendirir.
# Üretimde backend'in yayında olduğu adresi verin (ör. https://api.d2grup.com).
VITE_API_URL=

# Frontend adresi — göreli görsel ('assets/...') önizlemelerini doğru göstermek için.
VITE_FRONTEND_URL=http://localhost:3000
