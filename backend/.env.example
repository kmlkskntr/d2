# ============================================================
# D2 GRUP Backend — Ortam Değişkenleri
# Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
# ============================================================

# Sunucu portu
PORT=4000

# Veritabanı bağlantısı (varsayılan: SQLite dosyası)
# PostgreSQL için: postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./dev.db"

# JWT gizli anahtarı — üretimde MUTLAKA uzun ve rastgele bir değerle değiştirin
JWT_SECRET="degistirin-uzun-rastgele-bir-anahtar"
JWT_EXPIRES_IN="7d"

# CORS: Frontend ve admin panelinin çalıştığı adresler (virgülle ayrılır)
CORS_ORIGINS="http://localhost:3000,http://localhost:5174"

# İlk admin kullanıcısı (seed sırasında oluşturulur)
ADMIN_EMAIL="admin@d2grup.com"
ADMIN_PASSWORD="D2grup!2026"

# Yüklenen dosyaların erişileceği temel URL (boşsa istekten türetilir)
PUBLIC_URL="http://localhost:4000"
